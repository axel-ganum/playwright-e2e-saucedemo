{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "bundler",

    "types": ["node", "@playwright/test"],

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true
  },

  "include": [
    "tests",
    "pages",
    "fixtures",
    "playwright.config.ts"
  ]
}